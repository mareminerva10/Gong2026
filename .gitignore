# Service-account / credential files — never commit
*.json
!*.ipynb_checkpoints/*.json
gong2026-*.json
**/service-account*.json
**/credentials*.json
*.env

# Firebase Hosting config (Spark static-export deploy) — these are
# config, not credentials; firebase deploy tokens live in CI secrets.
!firebase.json
!.firebaserc

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Data: hand-curated inputs tracked; raw pulls, caches, and outputs ignored.
# Pattern: parent ignores everything in data/, then whitelist specific files.
data/*
!data/
!data/labeled_cases.csv
!data/README.md
# Defense in depth — explicit re-ignores so a future !data/foo/ exception
# can't accidentally pull in caches or raw API dumps.
data/*.parquet
data/**/*.parquet
data/*_raw*
data/molit_cache/

# Curated public-deploy snapshot. Only these two specific files are
# whitelisted — every other parquet/file under data/snapshot/ stays
# ignored, so a cache directory or large panel can't sneak into the
# snapshot namespace. tests/test_no_raw_payloads.py asserts the same
# rule at the git-index level.
!data/snapshot/
!data/snapshot/dashboard_pilot_contract.parquet
!data/snapshot/pilot_legal_dong_manifest.parquet

# Generated plots
outputs/

# Static export output for Firebase Hosting — regenerated each deploy
# by `python export_static_dashboard.py`; not a source artifact.
public/

# Firebase CLI local state (deploy history, hashes, debug log).
# Generated by `firebase deploy` / `firebase serve`; never source.
.firebase/
firebase-debug.log

# Local dashboard process marker
.dashboard_server.pid

# IDE configuration
.idea/
